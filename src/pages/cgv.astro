function renderContent(text) {
  if (!text) return '';
  const lines = text.split('\n');
  let html = '';
  let inList = false;
  let inTable = false;

  for (let i = 0; i < lines.length; i++) {
    let line = lines[i];

    if (line.trim().startsWith('|')) {
      if (!inTable) {
        inTable = true;
        const headers = line.split('|').filter(c => c.trim()).map(c => c.trim());
        html += '<table class="cgv-table"><thead><tr>';
        headers.forEach(h => html += `<th>${h}</th>`);
        html += '</tr></thead><tbody>';
        if (lines[i + 1] && lines[i + 1].includes('---')) i++;
        continue;
      } else {
        const cells = line.split('|').filter(c => c.trim()).map(c => c.trim());
        html += '<tr>';
        cells.forEach(c => html += `<td>${formatInline(c)}</td>`);
        html += '</tr>';
        continue;
      }
    } else if (inTable) {
      html += '</tbody></table>';
      inTable = false;
    }

    if (line.trim().startsWith('- ')) {
      if (!inList) {
        html += '<ul class="cgv-list">';
        inList = true;
      }
      html += `<li>${formatInline(line.trim().substring(2))}</li>`;
      continue;
    } else if (inList && line.trim() === '') {
      html += '</ul>';
      inList = false;
      continue;
    } else if (inList) {
      html += '</ul>';
      inList = false;
    }

    if (line.trim()) {
      html += `<p>${formatInline(line)}</p>`;
    }
  }

  if (inList) html += '</ul>';
  if (inTable) html += '</tbody></table>';
  return html;
}

function formatInline(text) {
  return text.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
}
