<BaseLayout
  title="Conditions Générales de Vente | Axel Plaisance"
  description="CGV d'Axel Plaisance, développeur web freelance à Lorient. Prestations B2B de création et refonte de sites web pour PME."
>
  <main class="cgv-page">
    <header class="cgv-header">
      <p class="cgv-eyebrow">Document légal</p>
      <h1>Conditions Générales de Vente</h1>
      <p class="cgv-meta">Version 1.1 — En vigueur à compter du 12 mai 2026</p>
      <p class="cgv-intro">
        Les présentes CGV régissent les prestations de création et refonte de sites web
        fournies par Axel Plaisance à ses clients professionnels.
      </p>
    </header>

    <nav class="cgv-toc" aria-label="Sommaire des articles">
      <h2>Sommaire</h2>
      <ol>
        {articles.map((article) => (
          <li>
            <a href={`#article-${article.num.replace(/\s+/g, '-')}`}>
              <span class="toc-num">Article {article.num}</span>
              <span class="toc-title">{article.title}</span>
            </a>
          </li>
        ))}
      </ol>
    </nav>

    <section class="cgv-content">
      {articles.map((article) => (
        <details class="cgv-article" id={`article-${article.num.replace(/\s+/g, '-')}`} open>
          <summary>
            <span class="article-num">Article {article.num}</span>
            <span class="article-title">{article.title}</span>
            <svg class="chevron" width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
              <path d="M5 7.5L10 12.5L15 7.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </summary>

          <div class="article-body">
            {article.identification && (
              <>
                <p>{article.intro}</p>
                <dl class="prestataire-fiche">
                  <dt>Identité</dt><dd>{prestataire.nom}</dd>
                  <dt>Statut</dt><dd>{prestataire.statut}</dd>
                  <dt>Adresse</dt><dd>{prestataire.adresse}</dd>
                  <dt>Téléphone</dt><dd><a href={`tel:+33${prestataire.tel.replace(/\s/g, '').substring(1)}`}>{prestataire.tel}</a></dd>
                  <dt>Email</dt><dd><a href={`mailto:${prestataire.email}`}>{prestataire.email}</a></dd>
                  <dt>Site web</dt><dd>{prestataire.site}</dd>
                  <dt>SIRET</dt><dd>{prestataire.siret}</dd>
                  <dt>Code APE</dt><dd>{prestataire.ape}</dd>
                  <dt>Régime fiscal</dt><dd>{prestataire.tva}</dd>
                  <dt>Hébergeur du site</dt><dd>{prestataire.hebergeur}</dd>
                  <dt>RC Professionnelle</dt><dd>{prestataire.rcpro} Attestation disponible sur simple demande.</dd>
                </dl>
                <p><em>Ci-après dénommé « le Prestataire ».</em></p>
              </>
            )}

            {article.sections && article.sections.map((section) => (
              <div class="article-section">
                <h3>
                  <span class="section-num">{section.sub}</span>
                  {section.title}
                </h3>
                <div set:html={renderContent(section.content)} />
              </div>
            ))}

            {article.content && (
              <div set:html={renderContent(article.content)} />
            )}
          </div>
        </details>
      ))}
    </section>

    <footer class="cgv-footer">
      <p>Document mis à jour le 10/05/2026 — Version 1.1</p>
      <p>Axel PLAISANCE — Création de sites web — 7 Rue Molière, 56600 LANESTER</p>
      <p>SIRET 104 517 040 00010 — <a href="mailto:contact@axelplaisance.fr">contact@axelplaisance.fr</a></p>
    </footer>
  </main>
</BaseLayout>

