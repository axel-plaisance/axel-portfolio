---
// ProjectCard.astro — Carte projet "en cours" (BTP / Sport / Commerce).
//
// Iteration v1.4 (2026-05-12) — Regle universelle d'alignement vertical :
//   - Ajout de h-full + flex-col (manquait : pour egalisation via items-stretch).
//   - mt-auto sur la meta (au lieu de mt-6) : meta callee en bas, peu importe
//     la longueur de la description.
//   - min-h-[28px] sur le bloc tags (1 ligne — pire cas mobile).
//   - min-h sur titre et description : calibre sur le PIRE CAS, qui est
//     /realisations (descriptions 290-350 car = 8-10 lignes desktop).
//     Consequence assumee : sur /index (descriptions courtes ~120 car), un
//     espace vide apparait sous la description — c'est exactement ce que
//     demande la regle v1.4 (cf. spec @design §3.3) : "mieux un espace vide
//     qu'un desalignement". Pas de prop `density` ajoutee : la complexite
//     supplementaire ne se justifie pas (les deux contextes restent visuellement
//     coherents, et un seul composant = une seule source de verite).
//
// Cf. specs : 02-design/iteration-v1.4-design.md §3.3 + §5.

export interface Props {
  sector: string; // ex: "BTP — COUVREUR"
  name: string;
  description: string;
  meta: string; // ex: "Livraison juin 2026"
  status?: string;
  // Variante du visuel SVG (selection du placeholder editorial)
  visual?: 'btp' | 'sport' | 'commerce' | 'default';
}

const { sector, name, description, meta, status = 'EN COURS', visual = 'default' } = Astro.props;
---

<article class="h-full flex flex-col bg-surface border border-border-light rounded-lg p-6 lg:p-8 transition-all duration-300 ease-editorial hover:border-border hover:-translate-y-0.5">
  <!-- Visuel SVG editorial (placeholder sobre, pas de photo stock)
       v1.4 : aspect-[4/3] garantit deja une hauteur uniforme — pas de min-h. -->
  <div class="relative aspect-[4/3] bg-ivoire border border-border-light rounded mb-6 overflow-hidden">
    <!-- Mockup navigateur sobre -->
    <svg
      viewBox="0 0 400 300"
      class="w-full h-full"
      aria-hidden="true"
      preserveAspectRatio="xMidYMid slice"
    >
      <!-- Barre navigateur -->
      <rect x="0" y="0" width="400" height="32" fill="#EDE7DA" />
      <circle cx="16" cy="16" r="4" fill="#C9C1AE" />
      <circle cx="32" cy="16" r="4" fill="#C9C1AE" />
      <circle cx="48" cy="16" r="4" fill="#C9C1AE" />
      <rect x="80" y="8" width="200" height="16" rx="2" fill="#DDD7C8" />

      <!-- Contenu (variantes selon secteur) -->
      {visual === 'btp' && (
        <>
          <rect x="32" y="64" width="160" height="12" fill="#2A2520" />
          <rect x="32" y="84" width="240" height="8" fill="#C9C1AE" />
          <rect x="32" y="100" width="200" height="8" fill="#C9C1AE" />
          <rect x="32" y="140" width="80" height="80" fill="#DDD7C8" stroke="#C9C1AE" />
          <rect x="128" y="140" width="80" height="80" fill="#DDD7C8" stroke="#C9C1AE" />
          <rect x="224" y="140" width="80" height="80" fill="#DDD7C8" stroke="#C9C1AE" />
          <rect x="32" y="240" width="120" height="24" rx="2" fill="#2A2520" />
        </>
      )}
      {visual === 'sport' && (
        <>
          <rect x="32" y="64" width="200" height="14" fill="#2A2520" />
          <rect x="32" y="88" width="280" height="8" fill="#C9C1AE" />
          <rect x="32" y="104" width="160" height="8" fill="#C9C1AE" />
          <circle cx="80" cy="180" r="32" fill="none" stroke="#2A2520" stroke-width="2" />
          <rect x="140" y="160" width="180" height="8" fill="#DDD7C8" />
          <rect x="140" y="176" width="140" height="8" fill="#DDD7C8" />
          <rect x="140" y="192" width="160" height="8" fill="#DDD7C8" />
          <rect x="32" y="240" width="120" height="24" rx="2" fill="#2A2520" />
        </>
      )}
      {visual === 'commerce' && (
        <>
          <rect x="32" y="64" width="180" height="12" fill="#2A2520" />
          <rect x="32" y="84" width="240" height="8" fill="#C9C1AE" />
          <rect x="32" y="120" width="100" height="100" fill="#DDD7C8" stroke="#C9C1AE" />
          <rect x="148" y="120" width="100" height="100" fill="#DDD7C8" stroke="#C9C1AE" />
          <rect x="264" y="120" width="100" height="100" fill="#DDD7C8" stroke="#C9C1AE" />
          <rect x="32" y="240" width="120" height="24" rx="2" fill="#2A2520" />
        </>
      )}
      {visual === 'default' && (
        <>
          <rect x="32" y="64" width="160" height="12" fill="#2A2520" />
          <rect x="32" y="84" width="240" height="8" fill="#C9C1AE" />
          <rect x="32" y="100" width="200" height="8" fill="#C9C1AE" />
          <rect x="32" y="140" width="336" height="80" fill="#DDD7C8" />
        </>
      )}
    </svg>
  </div>

  <!-- Statut tag — v1.4 : min-h-[28px] (1 ligne de tag) pour stabiliser
       la zone meme si le wrap survient sur mobile (col ~272px utile). -->
  <div class="flex flex-wrap gap-2 mb-3 min-h-[28px]">
    <span class="inline-block px-2 py-1 bg-ivoire border border-border-light font-mono text-eyebrow tracking-eyebrow uppercase text-ink rounded">
      {status}
    </span>
    <span class="inline-block px-2 py-1 font-mono text-eyebrow tracking-eyebrow uppercase text-mono">
      {sector}
    </span>
  </div>

  <!-- Nom — v1.4 : min-h-[64px] (2 lignes serif h4 desktop max constate). -->
  <h3 class="font-serif text-h4 text-ink min-h-[64px]">{name}</h3>

  <!-- Description — v1.4 : min-h calibre sur le PIRE CAS (/realisations,
       descriptions 290-350 car = 8-10 lignes). Sur /index (descriptions
       courtes), espace vide assume sous la description (cf. spec @design §3.3). -->
  <p class="text-small text-ink-soft mt-3 min-h-[200px] lg:min-h-[180px]">{description}</p>

  <!-- Meta — v1.4 : mt-auto (colle en bas peu importe la longueur description). -->
  <p class="text-micro font-mono text-mono mt-auto pt-6">{meta}</p>
</article>
