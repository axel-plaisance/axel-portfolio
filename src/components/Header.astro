---
// Header.astro — Navigation principale sticky.
// v2.1 (2026-05-25) — FIX bug menu mobile :
//   - z-index : z-40 → z-[60] (passe au-dessus du header en z-50)
//   - Fond ivoire 100% opaque (plus de transparence accidentelle)
//   - Ajout de la touche Escape pour fermer le menu
//   - Empêche le scroll du body de manière plus robuste

const currentPath = Astro.url.pathname;
const normalizedPath = currentPath === '/' ? '/' : currentPath.replace(/\/$/, '');

const navLinks = [
  { href: '/', label: 'Accueil' },
  { href: '/services', label: 'Services' },
  { href: '/automatisations', label: 'Automatisations' },
  { href: '/realisations', label: 'Réalisations' },
  { href: '/contact', label: 'Contact' },
];

const isActive = (href: string): boolean => {
  if (href === '/') return normalizedPath === '/';
  return normalizedPath === href || normalizedPath.startsWith(href + '/');
};
---

<header
  class="sticky top-0 z-50 w-full bg-ivoire/85 backdrop-blur-md border-b border-border-light"
>
  <div class="container-editorial flex items-center justify-between h-16 lg:h-18">
    <!-- Logo / wordmark -->
    <a
      href="/"
      class="font-serif text-h5 text-ink hover:text-ink-soft transition-colors duration-200"
      aria-label="Axel Plaisance — Retour à l'accueil"
    >
      Axel Plaisance<span class="text-mono">.</span>
    </a>

    <!-- Navigation desktop (cachée < lg) -->
    <nav class="hidden lg:flex items-center gap-6 xl:gap-8" aria-label="Navigation principale">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class:list={[
              'text-body text-ink hover:text-mono transition-colors duration-200',
              isActive(link.href) && 'underline underline-offset-8 decoration-1 decoration-ink',
            ]}
            aria-current={isActive(link.href) ? 'page' : undefined}
          >
            {link.label}
          </a>
        ))
      }
    </nav>

    <!-- CTA desktop -->
    <a
      href="/contact"
      class="hidden lg:inline-flex items-center px-5 py-2.5 bg-ink text-ivoire text-small font-medium rounded hover:bg-[#1F1B17] transition-all duration-200 hover:-translate-y-0.5"
    >
      Discutons
    </a>

    <!-- Burger mobile (visible < lg) -->
    <button
      class="burger lg:hidden flex flex-col gap-1.5 p-2 -mr-2 relative z-[70]"
      aria-label="Ouvrir le menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
      type="button"
    >
      <span class="burger-line"></span>
      <span class="burger-line"></span>
      <span class="burger-line"></span>
    </button>
  </div>

  <!-- Menu mobile (overlay plein écran) -->
  <!-- FIX v2.1 :
       - z-[60] : passe au-dessus du header sticky (z-50)
       - bg-ivoire opaque (sans transparence)
       - top-0 (couvre tout l'écran depuis le haut, plus de superposition)
       - pt-20 : padding-top pour laisser l'espace du header visible
  -->
  <div
    id="mobile-menu"
    class="lg:hidden fixed inset-0 top-0 bg-ivoire z-[60] hidden flex-col px-6 pt-20 pb-6"
    aria-hidden="true"
  >
    <nav class="flex flex-col gap-6 mt-8" aria-label="Navigation mobile">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class:list={[
              'text-h3 font-serif text-ink',
              isActive(link.href) && 'underline underline-offset-8 decoration-1',
            ]}
          >
            {link.label}
          </a>
        ))
      }
    </nav>
    <a
      href="/contact"
      class="mt-auto inline-flex justify-center items-center w-full px-5 py-4 bg-ink text-ivoire text-body font-medium rounded"
    >
      Discutons
    </a>
  </div>
</header>

<script is:inline>
  // Toggle du menu mobile + Escape pour fermer
  (function () {
    const burger = document.querySelector('.burger');
    const menu = document.getElementById('mobile-menu');
    if (!burger || !menu) return;

    const closeMenu = () => {
      burger.setAttribute('aria-expanded', 'false');
      burger.setAttribute('aria-label', 'Ouvrir le menu');
      menu.setAttribute('aria-hidden', 'true');
      menu.classList.add('hidden');
      menu.classList.remove('flex');
      document.body.style.overflow = '';
    };

    const openMenu = () => {
      burger.setAttribute('aria-expanded', 'true');
      burger.setAttribute('aria-label', 'Fermer le menu');
      menu.setAttribute('aria-hidden', 'false');
      menu.classList.remove('hidden');
      menu.classList.add('flex');
      document.body.style.overflow = 'hidden';
    };

    burger.addEventListener('click', () => {
      const isOpen = burger.getAttribute('aria-expanded') === 'true';
      if (isOpen) closeMenu();
      else openMenu();
    });

    // Ferme le menu en cliquant sur un lien
    menu.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', closeMenu);
    });

    // Ferme le menu avec la touche Escape
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && burger.getAttribute('aria-expanded') === 'true') {
        closeMenu();
      }
    });
  })();
</script>