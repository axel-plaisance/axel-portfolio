---
// Carousel.astro v2 — CSS pur, sans Tailwind arbitrary values.
// Mode carrousel actif uniquement < 1024px (mobile + tablette).
// Sur desktop : passthrough total (les enfants se retrouvent dans la grille parent).

interface Props {
  id: string;
  ariaLabel: string;
}

const { id, ariaLabel } = Astro.props;
---

<div class="carousel-wrapper" data-carousel-id={id}>
  <div
    class="carousel-track"
    role="region"
    aria-label={ariaLabel}
    aria-roledescription="carousel"
  >
    <slot />
  </div>

  <div class="carousel-dots" aria-hidden="true">
    <!-- Dots générés par le script -->
  </div>
</div>

<style>
  /* ========================================== */
  /* MODE MOBILE / TABLETTE < 1024px            */
  /* ========================================== */
  @media (max-width: 1023px) {
    .carousel-wrapper {
      display: block !important;
      width: 100%;
    }

    .carousel-track {
      display: flex !important;
      gap: 1rem !important;
      overflow-x: auto !important;
      scroll-snap-type: x mandatory !important;
      scroll-padding-left: 1.5rem !important;
      padding: 0.5rem 1.5rem 1rem !important;
      margin: 0 -1.5rem !important;
      scrollbar-width: none;
      -ms-overflow-style: none;
      -webkit-overflow-scrolling: touch;
    }

    .carousel-track::-webkit-scrollbar {
      display: none !important;
    }

    /* Chaque enfant devient une slide */
    .carousel-track > * {
      flex: 0 0 85% !important;
      scroll-snap-align: start !important;
      scroll-snap-stop: always !important;
      min-width: 0;
    }

    .carousel-dots {
      display: flex !important;
      justify-content: center;
      gap: 0.5rem;
      margin-top: 1.5rem;
    }
  }

  /* ========================================== */
  /* MODE DESKTOP >= 1024px : passthrough       */
  /* ========================================== */
  @media (min-width: 1024px) {
    .carousel-wrapper {
      display: contents !important;
    }

    .carousel-track {
      display: contents !important;
    }

    .carousel-dots {
      display: none !important;
    }
  }

  /* Dots */
  .carousel-dots button {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: rgba(42, 38, 37, 0.2);
    border: none;
    padding: 0;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .carousel-dots button[data-active="true"] {
    background: rgba(42, 38, 37, 0.8);
    width: 24px;
    border-radius: 4px;
  }
</style>

<script is:inline>
  (function () {
    document.querySelectorAll('.carousel-wrapper').forEach((wrapper) => {
      const track = wrapper.querySelector('.carousel-track');
      const dotsContainer = wrapper.querySelector('.carousel-dots');
      if (!track || !dotsContainer) return;

      const slides = Array.from(track.children);
      if (slides.length === 0) return;

      // Génère un dot par slide
      slides.forEach((_, index) => {
        const dot = document.createElement('button');
        dot.setAttribute('aria-label', `Aller à la carte ${index + 1} sur ${slides.length}`);
        dot.setAttribute('data-active', index === 0 ? 'true' : 'false');
        dot.addEventListener('click', () => {
          slides[index].scrollIntoView({
            behavior: 'smooth',
            inline: 'start',
            block: 'nearest',
          });
        });
        dotsContainer.appendChild(dot);
      });

      const dots = Array.from(dotsContainer.children);

      const updateActiveDot = () => {
        const trackRect = track.getBoundingClientRect();
        const centerX = trackRect.left + trackRect.width / 2;

        let closestIndex = 0;
        let closestDistance = Infinity;

        slides.forEach((slide, index) => {
          const slideRect = slide.getBoundingClientRect();
          const slideCenterX = slideRect.left + slideRect.width / 2;
          const distance = Math.abs(slideCenterX - centerX);

          if (distance < closestDistance) {
            closestDistance = distance;
            closestIndex = index;
          }
        });

        dots.forEach((dot, index) => {
          dot.setAttribute('data-active', index === closestIndex ? 'true' : 'false');
        });
      };

      track.addEventListener('scroll', () => {
        window.requestAnimationFrame(updateActiveDot);
      });

      window.addEventListener('resize', updateActiveDot);
    });
  })();
</script>