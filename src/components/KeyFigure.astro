---
// KeyFigure.astro — Bloc chiffre cle editorial.
// Point d orgue typographique pur : eyebrow + chiffre geant + caption (+ subline).
// Bloc respiration encore plus aere que EditorialQuote.
// Cf. iteration-v1.md §3.E.

export interface Props {
  // Etiquette mono (ex: "UN ENGAGEMENT CLAIR")
  eyebrow: string;
  // Chiffre cle (ex: "30 jours max.")
  figure: string;
  // Phrase qui developpe le chiffre (ex: "pour livrer votre site...")
  caption: string;
  // Sous-ligne italique optionnelle (precision, frappe seche)
  subline?: string;
}

const { eyebrow, figure, caption, subline } = Astro.props;
---

<!-- Padding vertical max (112 / 128 / 160px) — c est le chiffre fort de la page -->
<section class="container-editorial py-28 md:py-32 lg:py-40 relative">
  <div class="max-w-5xl mx-auto text-center relative z-10 fade-in">
    <!-- Eyebrow mono 11px -->
    <p class="font-mono text-eyebrow tracking-eyebrow uppercase text-mono mb-12">
      {eyebrow}
    </p>

    <!-- Chiffre geant : serif 72/96/120px, leading tres serre -->
    <p
      class="font-serif tracking-tighter text-ink text-[4.5rem] md:text-[6rem] lg:text-[7.5rem] leading-[0.95]"
    >
      {figure}
    </p>

    <!-- Caption : phrase explicative, 18-20px sans-serif -->
    <p class="text-lede md:text-[1.25rem] text-ink-soft mt-6">{caption}</p>

    <!-- Subline italique : nuance / precision contractuelle -->
    {subline && (
      <p class="text-small italic text-mono mt-3">{subline}</p>
    )}
  </div>
</section>
