---
// ApproachCard.astro — Carte editoriale Creation/Refonte (2 variants).
// Iteration v1.3 (2026-05-12) — Bascule des 3 niveaux v1.2 vers 2 axes
// Creation/Refonte. Remplace LevelCard.astro (variant large) et
// LevelTeaserCard.astro (variant compact).
//
// Iteration v1.4 (2026-05-12) — Regle universelle d'alignement vertical :
// chaque zone interne possede un min-h-[Xpx] dimensionne sur le pire cas
// actuel + 1 ligne de marge. Cf. specs : 02-design/iteration-v1.4-design.md
// §3.1 (variant large) et §3.2 (variant compact).
// Pattern : conteneur racine `h-full flex flex-col` + `mt-auto` sur footer.
//
// Cf. specs precedentes : 02-design/iteration-v1.3-design.md §1
//
// Pattern de reference : AutomationCard (structure) + PricingCard (mecanique
// hover/flex). h-full + flex-col + mt-auto sur le footer = CTAs alignes
// horizontalement quand le parent grille est en items-stretch.
//
// Variant `large` (page Services Section 2 — Creation vs Refonte cote a cote) :
//   - Eyebrow + H3 + description + hairline + sous-eyebrow + liste 5 features
//     + paragraphe "Ideal pour" italique + footer avec lien souligne.
//   - Padding 32px mobile / 48px desktop. Fond bg-surface.
//
// Variant `compact` (page Accueil — mini-cartes Creation/Refonte) :
//   - Eyebrow + H3 + description courte + footer avec lien souligne.
//   - PAS de liste features, PAS de "Ideal pour".
//   - Padding 24px mobile / 32px desktop. Fond bg-surface.

export interface Props {
  // Variant : large (page Services) ou compact (page Accueil)
  size: 'large' | 'compact';
  // Eyebrow mono ("CRÉATION" / "REFONTE")
  eyebrow: string;
  // Titre H3 serif
  title: string;
  // Description : 3 phrases (large) / 1 phrase courte (compact)
  description: string;
  // Liste 5 items — variant `large` uniquement
  features?: string[];
  // Mention italique "Idéal pour : ..." — variant `large` uniquement
  idealFor?: string;
  // Ancre optionnelle (pose id="..." + scroll-mt-24 sur l'article racine)
  anchor?: string;
  // URL du lien CTA
  linkHref: string;
  // Libelle du lien CTA (defaut : "Demander un devis →" en large,
  // "En savoir plus →" en compact)
  linkLabel?: string;
}

const {
  size,
  eyebrow,
  title,
  description,
  features,
  idealFor,
  anchor,
  linkHref,
  linkLabel,
} = Astro.props;

// Libelle par defaut selon le variant
const defaultLabel = size === 'large' ? 'Demander un devis →' : 'En savoir plus →';
const ctaLabel = linkLabel ?? defaultLabel;
---

<article
  id={anchor}
  class:list={[
    // h-full obligatoire : egalisation des hauteurs via parent items-stretch.
    // flex-col + mt-auto sur footer = CTAs alignes horizontalement.
    'h-full flex flex-col rounded-lg bg-surface border border-border-light transition-all duration-300 ease-editorial hover:border-border hover:-translate-y-1',
    // scroll-mt-24 (96px = 72px header sticky + respiration) si ancre fournie
    anchor && 'scroll-mt-24',
    // Padding selon variant
    size === 'large' ? 'p-8 lg:p-12' : 'p-6 lg:p-8',
  ]}
>
  {/* ========== HEADER ========== */}
  {/* Eyebrow mono 11px — h-4 (16px, 1 ligne fixe) v1.4 */}
  <p class="font-mono text-eyebrow tracking-eyebrow uppercase text-mono h-4">
    {eyebrow}
  </p>

  {/* Titre H3 serif — 32px desktop / 24px mobile en large, 24px/22px en compact
       v1.4 : min-h calibre sur le pire cas constate + 1 ligne. */}
  <h3
    class:list={[
      'font-serif tracking-tighter text-ink mt-3 leading-snug',
      size === 'large'
        ? 'text-h4 lg:text-h3 min-h-[88px] lg:min-h-[80px]'
        : 'text-h4 lg:text-[1.5rem] min-h-[72px]',
    ]}
  >
    {title}
  </h3>

  {/* Description — 16-17px en large, 14-15px en compact
       v1.4 : min-h selon spec @design §3.1/§3.2. */}
  <p
    class:list={[
      'text-ink-soft leading-relaxed max-w-prose',
      size === 'large'
        ? 'text-body lg:text-[1.0625rem] mt-4 min-h-[168px] lg:min-h-[140px]'
        : 'text-small lg:text-[0.9375rem] mt-3 min-h-[56px] lg:min-h-[28px]',
    ]}
  >
    {description}
  </p>

  {/* ========== BLOCS SPECIFIQUES VARIANT LARGE ========== */}
  {size === 'large' && features && features.length > 0 && (
    <>
      {/* Hairline de separation (h-px structurel + my-6 = 48px de marges v1.4) */}
      <hr class="border-t border-border-light my-6 h-px" />

      {/* Sous-eyebrow mono : "CE QUE ÇA INCLUT" — h-4 (1 ligne fixe) v1.4 */}
      <p class="font-mono text-eyebrow tracking-eyebrow uppercase text-mono h-4">
        CE QUE ÇA INCLUT
      </p>

      {/* Liste 5 features — puces "•" mono, gap-2 (8px) entre items
           v1.4 : min-h-[180px] mobile / min-h-[160px] desktop (5 items × 28-32px + gaps) */}
      <ul class="flex flex-col gap-2 mt-4 min-h-[180px] lg:min-h-[160px]">
        {features.map((feature) => (
          <li class="flex items-start gap-3 text-small lg:text-body text-ink">
            <span class="text-mono font-mono mt-0.5" aria-hidden="true">•</span>
            <span>{feature}</span>
          </li>
        ))}
      </ul>
    </>
  )}

  {/* Mention "Ideal pour" — variant large : zone CRITIQUE d'alignement v1.4.
       Si idealFor absent : placeholder invisible (aria-hidden) qui preserve
       la place dans la rangee (Option A spec @design §4.5). */}
  {size === 'large' && (
    idealFor ? (
      <p class="font-serif italic text-small text-ink-soft mt-6 min-h-[120px] lg:min-h-[72px]">
        {idealFor}
      </p>
    ) : (
      <p class="mt-6 min-h-[120px] lg:min-h-[72px]" aria-hidden="true">&nbsp;</p>
    )
  )}

  {/* ========== FOOTER (mt-auto colle en bas) ========== */}
  {/* Le lien souligne ghost ink est dans le footer pour alignement parfait
       des CTAs entre les 2 cartes (parent items-stretch + h-full). */}
  <footer
    class:list={[
      'mt-auto',
      size === 'large' ? 'pt-6' : 'pt-4',
    ]}
  >
    <a
      href={linkHref}
      class:list={[
        'inline-flex items-center gap-2 font-medium text-ink underline underline-offset-4 decoration-border hover:decoration-ink transition-all duration-200',
        size === 'large' ? 'text-body' : 'text-small',
      ]}
    >
      {ctaLabel}
    </a>
  </footer>
</article>
